.hippocampus/
hippocampus-data/

# SQLite
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Obsidian mirrors / vaults (contain user's synthesized fragments)
devin-vault/
hippocampus-vault/
Fragments/
.archive/

# Logs
*.log
logs/

# Backup copies we write before mutating user files
*.bak
*.pre-hippocampus.bak
*.pre-hippo-hooks.bak
*.*.pre-hippocampus.bak
*.*.pre-hippo-hooks.bak

# ---------------------------------------------------------------------------
# Models / caches (large, per-user)
# ---------------------------------------------------------------------------
models/
.cache/
.huggingface/

# ---------------------------------------------------------------------------
# Secrets & credentials — NEVER commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets/
credentials/
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
id_rsa*
id_ed25519*
id_ecdsa*
*.token
api_keys*
.netrc

# AWS / GCP / Azure credentials accidentally placed in a repo
.aws/
.gcp/
.azure/
service-account*.json

